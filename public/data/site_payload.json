  "notes": [
    {
      "label": "Why Boscastle",
      "text": "Boscastle is a flashy catchment. Steep slopes and slow-draining geology can produce rapid river response during short, localised rainfall bursts."
    },
    {
      "label": "How it is observed",
      "text": "The observatory combines LiDAR, an ultrasonic altimeter, and camera observations to capture how rainfall translates into channel response."
    },
    {
      "label": "Next public additions",
      "text": "Rainfall from station 49149 will be added once that feed is integrated into the public export."
    }
  ],
